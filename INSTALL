#Author : Dinindu Senanayake
# Use Miniforge3 module or Pixi  ( Please don't use Ananconda or Miniconda )
# Load KIR-utils module after purge to bring in uv
module purge 
module load Miniforge3 KIR-utils
source $(conda info --base)/etc/profile.d/conda.sh
export PYTHONNOUSERSITE=1

# Create the env — rapids metapackage pulls in cuml, cudf, cupy, etc.
mamba create -n gh200-test -c rapidsai -c conda-forge -c nvidia \
    rapids=25.04 python=3.11 cuda-version=12.6

conda activate gh200-test

# PyTorch (cu124 wheels are fine against a 12.6 driver)
# need 2.5+ to match the trasnformers in use 
pip install "torch>=2.5" --index-url https://download.pytorch.org/whl/cu124

# Remaining deps
pip install \
    transformers>=4.43.0 \
    accelerate>=0.33.0 \
    tokenizers>=0.19.0 \
    sentencepiece>=0.2.0 \
    huggingface_hub>=0.24.0 \
    protobuf>=3.20.0 \
    openmm>=8.1.0

# flash-attn last, after torch is settled
pip install flash-attn --no-build-isolation
